<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tip">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plan Your Trip"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:layout_marginBottom="20dp"/>


        <!-- ROUTE DETAILS -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Route Details"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/startLocation"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Start Location"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"/>

                <EditText
                    android:id="@+id/destinationLocation"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Destination"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/intermediateStops"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Intermediate Stops (optional)"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/startTime"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Start Date &amp; Time"
                    android:focusable="false"
                    android:clickable="true"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/endTime"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="End Date &amp; Time"
                    android:focusable="false"
                    android:clickable="true"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- EMERGENCY CONTACT -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emergency Contact"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/contactName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Contact Name"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"/>

                <EditText
                    android:id="@+id/contactNumber"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Contact Number"
                    android:inputType="phone"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>


        <!-- OPTIONAL DETAILS -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optional Details"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/hotelName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Hotel Name"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"/>

                <EditText
                    android:id="@+id/transportType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Transport Type"
                    android:background="@drawable/edittext_bg"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/previewRouteBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Preview Route on Map"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/edittext_bg"
            android:textColor="#1F92E4"/>

        <!-- START TRIP BUTTON -->

        <Button
            android:id="@+id/startTripBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Start Trip"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_sheild"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</ScrollView>