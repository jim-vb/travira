<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tip">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 🔼 Heading ekdum top & sides se chipki rahegi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/header_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plan Your Trip"
                android:gravity="center"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginStart="16dp" />

        </LinearLayout>

        <!-- 🔽 Baaki sab content me 12dp sides & bottom ka gap -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <!-- 🟢 Section: Aadhaar Number -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                card_view:cardCornerRadius="10dp"
                card_view:cardElevation="4dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Identity Verification"
                        android:layout_gravity="center"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:text="Enter Full Name"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Name"
                        android:inputType="text"
                        android:maxLength="12"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>

                    <TextView
                        android:text="Enter Email id"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email Id"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:inputType="textEmailAddress"
                        android:textColor="#000000"/>

                    <TextView
                        android:text="Enter Aadhaar Number"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_adhaar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Aadhaar Number"
                        android:inputType="number"
                        android:maxLength="12"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 🟢 Section: Trip Route (Start, Destination, Stops) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                card_view:cardCornerRadius="10dp"
                card_view:cardElevation="4dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Trip Route"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <!-- Starting Point -->
                    <TextView
                        android:text="Enter starting location"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Starting Point"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>

                    <!-- Stops -->
                    <TextView
                        android:text="Intermediate Stops (Optional)"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:id="@+id/stopContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp" />

                    <Button
                        android:id="@+id/btn_add_stop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Add Stop"
                        android:layout_marginTop="8dp"
                        android:backgroundTint="#2196F3"
                        android:textColor="#FFFFFF"/>

                    <!-- Destination -->
                    <TextView
                        android:text="Enter ending location"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_destination"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Destination"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 🟢 Section: Vehicle / Transport -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                card_view:cardCornerRadius="10dp"
                card_view:cardElevation="4dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Travel Information"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"/>

                    <TextView
                        android:text="Enter transportation (with vehicle no. if applicable)"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_vehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Vehicle / Public Transport"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>

                    <TextView
                        android:text="Enter hotel name (with landmark)"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_hotel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Hotel Name"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 🟢 Section: Emergency Contact -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                card_view:cardCornerRadius="10dp"
                card_view:cardElevation="4dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Emergency Contact details"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:text="Enter contact name"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_emergency_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Contact Name"
                        android:maxLines="1"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>

                    <TextView
                        android:text="Enter contact number"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/input_emergency_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Contact Number"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:background="@drawable/bg_edittext"
                        android:padding="10dp"
                        android:textColor="#000000"/>

                    <!-- Relation -->
                    <TextView
                        android:text="Relation"
                        android:textSize="14sp"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <Spinner
                        android:id="@+id/spinner_relation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:background="@drawable/bg_edittext"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 🔵 Generate Button -->
            <Button
                android:id="@+id/btn_generate_trip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generate Digital ID"
                android:layout_marginTop="8dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginBottom="10dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_generate_btn"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
