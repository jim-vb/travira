<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:id="@+id/quickAccessLayout"
    android:layout_marginTop="24dp"
    android:layout_marginLeft="20dp"
    android:layout_marginRight="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quick Access"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="12dp"
        android:paddingStart="8dp"/>

    <GridLayout
        android:id="@+id/quickAccessGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:orientation="horizontal"
        android:alignmentMode="alignMargins"
        android:rowOrderPreserved="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:id="@+id/viewIdButton"
            android:layout_margin="8dp"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginBottom="5dp"
                android:src="@drawable/id" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View My\nDigital ID"
                android:textSize="14sp"
                android:textColor="#212121"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_margin="8dp"
            android:id="@+id/planButton"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/plan"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trip Itinerary"
                android:textSize="14sp"
                android:textColor="#212121"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_margin="8dp"
            android:layout_columnWeight="1"
            android:id="@+id/alertButton"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_card">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/alert"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alert(s)\nHistory"
                android:textSize="14sp"
                android:textColor="#212121"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_margin="8dp"
            android:layout_columnWeight="1"
            android:id="@+id/sosButton"
            android:gravity="center"
            android:backgroundTint="#F50000"
            android:orientation="vertical"
            android:background="@drawable/bg_card">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/emergency"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOS\nPanic Button"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:gravity="center"/>
        </LinearLayout>

        <!-- isi tarah aur 3 cards banao (Itinerary, Geo Alerts, SOS Panic Button) -->
    </GridLayout>
</LinearLayout>
