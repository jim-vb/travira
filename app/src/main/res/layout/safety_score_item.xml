<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:id="@+id/safetyScoreLayout"
    android:padding="16dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="6dp">

    <!-- Semi Transparent Shield Icon -->
    <ImageView
        android:id="@+id/shieldIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:src="@drawable/outline_shield_24"
        android:background="@drawable/bg_sheild"
        android:scaleType="centerInside"/>

    <!-- Text Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toStartOf="@id/shieldIcon"
        android:layout_alignParentStart="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Safety Score"
            android:textSize="14sp"
            android:textColor="#212121"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/safetyScoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#388E3C"/>

            <TextView
                android:id="@+id/safetyScoreDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXCELLENT"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>