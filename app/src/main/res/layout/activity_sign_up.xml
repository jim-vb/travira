<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SignUp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_tip">

        <ImageView
            android:id="@+id/logoSignUp"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/logo"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/titleSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to Travira!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/logoSignUp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/subtitleSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up to continue"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/titleSignUp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/subtitleSignUp"
            app:layout_constraintBottom_toTopOf="@id/footerText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Name -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter Full Name *"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <EditText
                        android:id="@+id/nameEditTextSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Name"
                        android:background="@drawable/bg_edittext"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Email -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter Email ID *"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <EditText
                        android:id="@+id/emailEditTextSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Email"
                        android:inputType="textEmailAddress"
                        android:background="@drawable/bg_edittext"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Phone Number -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter Phone Number *"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_edittext"
                        android:padding="6dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="+91"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:paddingHorizontal="8dp"/>

                        <EditText
                            android:id="@+id/phoneNumberEditTextSignUp"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:hint="Phone Number"
                            android:inputType="number"
                            android:maxLength="10"
                            android:background="@android:color/transparent"/>
                    </LinearLayout>

                    <!-- Aadhaar -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter Aadhaar Number *"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <EditText
                        android:id="@+id/adhaarTextSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Aadhaar Number"
                        android:inputType="number"
                        android:maxLength="12"
                        android:background="@drawable/bg_edittext"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Password -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter Password *"
                        android:textSize="14sp"
                        android:textColor="#212121"/>

                    <EditText
                        android:id="@+id/passwordTextSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Password"
                        android:inputType="textPassword"
                        android:background="@drawable/bg_edittext"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:id="@+id/signupSwitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? Login"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Sign Up Button -->
                    <Button
                        android:id="@+id/signUpButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="SIGN UP"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:backgroundTint="#1976D2"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </ScrollView>

        <TextView
            android:id="@+id/footerText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="By continuing, you agree to our Terms and Privacy Policy"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Loading Spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center"/>

</FrameLayout>