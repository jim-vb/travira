<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Rounded corners -->
<!--    <corners android:radius="12dp" />-->

    <!-- Gradient background (light blue to light green) -->
    <gradient
        android:startColor="#D6EAF8"
    android:endColor="#D5F5E3"
    android:angle="0" />

    <!-- Optional border -->
    <stroke
        android:width="0dp"
        android:color="#00000000" />

    <!-- Padding inside the shape -->
    <padding
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp" />
</shape>
